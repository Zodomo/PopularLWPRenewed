<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="28"
    android:versionName="1.3.6"
    package="com.CatShockEntertainment.FreePopularLiveWallpaper"
    platformBuildVersionCode="19"
    platformBuildVersionName="4.4.2-1456859">
    <uses-sdk
        android:minSdkVersion="9"
        android:targetSdkVersion="19"/>
    <uses-feature
        android:glEsVersion="0x20000"
        android:required="true"/>
    <uses-feature
        android:name="android.software.live_wallpaper"
        android:required="true"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <application
        android:label="@string/app_name"
        android:icon="@drawable/icon"
        android:description="@string/app_description"
        android:allowBackup="true">
        <service
            android:label="@string/app_name"
            android:name="com.CatShockEntertainment.FreePopularLiveWallpaper.FreePopularLiveWallpaper"
            android:permission="android.permission.BIND_WALLPAPER"
            android:description="@string/app_description">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService"/>
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/popular"/>
        </service>
        <activity
            android:label="@string/app_name_launcher"
            android:icon="@drawable/icon"
            android:name="com.CatShockEntertainment.LiveWallpaperLib.LiveWallpaperLauncher"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
            android:theme="@android:style/Theme.WallpaperSettings"
            android:label="@string/settings"
            android:name="com.CatShockEntertainment.PopularLiveWallpaper.PopularLiveWallpaperSettings"
            android:exported="true"/>
        <activity
            android:name="com.google.ads.AdActivity"
            android:configChanges="smallestScreenSize|screenSize|uiMode|screenLayout|orientation|keyboardHidden|keyboard"/>
    </application>
</manifest>
