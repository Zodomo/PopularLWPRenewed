<?xml version="1.0" encoding="utf-8"?>
<com.CatShockEntertainment.ColorPicker.HSVView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="fill_vertical"
    android:orientation="horizontal"
    android:id="@+id/colorPickerHSV_linearLayout"
    android:paddingLeft="12dp"
    android:paddingTop="12dp"
    android:paddingRight="12dp"
    android:paddingBottom="6dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="400dp">
    <com.CatShockEntertainment.ColorPicker.SVView
        android:id="@+id/colorPickerHSV_SV"
        android:background="#ffff0000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="10dp"
        android:minWidth="200dp"
        android:minHeight="200dp"
        android:layout_weight="0.5"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minWidth="180dp"
        android:minHeight="200dp"
        android:layout_weight="0.5">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/colorPickerHSV_LinearLayout_H_HSector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.5">
            <com.CatShockEntertainment.ColorPicker.HView
                android:id="@+id/colorPickerHSV_H"
                android:background="#ffff0000"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="0dp"
                android:layout_marginRight="10dp"
                android:layout_weight="0.333"/>
            <com.CatShockEntertainment.ColorPicker.HSectorView
                android:id="@+id/colorPickerHSV_HSector"
                android:background="#ffff0000"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="0dp"
                android:layout_weight="0.333"/>
            <ImageView
                android:id="@+id/colorPickerHSV_Preview"
                android:background="#ffff0000"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="0dp"
                android:layout_weight="0.333"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.5">
            <Button
                android:id="@+id/colorPickerHSV_CancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:layout_weight="0.5"/>
            <Button
                android:id="@+id/colorPickerHSV_OkButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ok"
                android:layout_weight="0.5"/>
        </LinearLayout>
    </LinearLayout>
</com.CatShockEntertainment.ColorPicker.HSVView>
